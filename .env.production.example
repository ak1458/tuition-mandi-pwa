# =============================================================================
# Takhti — Vercel production environment
# =============================================================================
# Paste these into Vercel -> Project -> Settings -> Environment Variables
# Only "Production" environment. Do NOT commit a real .env.production file.
# =============================================================================

VITE_APP_ENV=production
VITE_LOCAL_MODE=false

# --- Supabase (public client values - safe to ship in browser) ---------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_REDIRECT_URL=https://YOUR_VERCEL_DOMAIN

# --- Razorpay (publishable key only - secret stays server-side) --------------
# Use rzp_test_* for staging, rzp_live_* for production.
VITE_RAZORPAY_KEY=rzp_test_XXXXXXXXXXXX

# --- Free launch toggle (optional) -------------------------------------------
# Grants Pro to all users until this date. Remove or leave blank for normal billing.
# VITE_FREE_LAUNCH_UNTIL=2026-12-31T23:59:59Z

# =============================================================================
# DO NOT SET THESE IN PRODUCTION:
# =============================================================================
# VITE_OPENROUTER_API_KEY    <- belongs in Supabase Edge Function secrets
# RAZORPAY_KEY_SECRET        <- belongs in Supabase Edge Function secrets
# SUPABASE_SERVICE_ROLE_KEY  <- belongs in Supabase Edge Function secrets
# GEMINI_API_KEY             <- belongs in Supabase Edge Function secrets
#
# See DEPLOYMENT.md for where each secret actually goes.
# =============================================================================
